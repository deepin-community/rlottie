+bool LOTData::includes(const LOTData *pointer) const {
+    if (this == pointer) {
+        return true;
+    }
+    if (type() != Type::ShapeGroup && type() != Type::Layer) {
+        return false;
+    }
+    for (LOTData *child : static_cast<const LOTGroupData *>(this)->mChildren) {
+        if (child->includes(pointer)) {
+            return true;
+        }
+    }
+    return false;
+}
